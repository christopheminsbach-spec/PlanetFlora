generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  predictions Prediction[]
}

model Prediction {
  id         Int      @id @default(autoincrement())
  imagePath  String
  result     String
  confidence Float
  createdAt  DateTime @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id])
}
