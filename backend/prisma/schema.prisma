datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String
  email     String   @unique
  password  String

  predictions Prediction[]
  favorites   Favorite[]
}

model Prediction {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  result    String
  confidence Float

  userId    Int?
  user      User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Favorite {
  id     Int @id @default(autoincrement())
  name   String

  userId Int
  user   User @relation(fields: [userId], references: [id])
}